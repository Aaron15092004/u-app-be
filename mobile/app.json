{
  "expo": {
    "name": "Ủ",
    "slug": "u-app",
    "version": "1.0.0",
    "scheme": "uapp",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF0DC"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.uapp.health",
      "buildNumber": "6",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Ủ to take photos for food recognition.",
        "NSPhotoLibraryUsageDescription": "Allow Ủ to access your photos for food logging.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.uapp.health",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFF0DC"
      },
      "package": "com.uapp.health",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.788882504008-fiebmvmkcnkk7290lu46cud4u7m6b5hr"
        }
      ],
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Ủ to access your photos for food logging.",
          "cameraPermission": "Allow Ủ to take photos for food recognition."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#4CAF50"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "de64aab7-1fc3-4244-b51c-906ac462aa12"
      }
    }
  }
}
