{
  "name": "u-app-backend",
  "version": "1.0.0",
  "type": "commonjs",
  "engines": { "node": ">=20.0.0" },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "seed": "tsx src/scripts/seed-exercises.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test:auth": "node --env-file=.env.test --require tsx/cjs --test src/api/auth/auth.integration.test.ts",
    "test:workouts": "node --env-file=.env.test --require tsx/cjs --test src/api/workouts/workouts.integration.test.ts",
    "test:exercises": "node --env-file=.env.test --require tsx/cjs --test src/api/exercises/exercises.integration.test.ts"
  },
  "dependencies": {
    "express": "^5.1.0",
    "mongoose": "^8.0.0",
    "zod": "^3.24.0",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "express-rate-limit": "^7.0.0",
    "multer": "^1.4.5-lts.1",
    "cloudinary": "^2.0.0",
    "firebase-admin": "^13.0.0",
    "dotenv": "^16.0.0",
    "resend": "^4.0.0",
    "google-auth-library": "^9.0.0",
    "apple-signin-auth": "^2.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "tsx": "^4.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/cors": "^2.8.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/bcryptjs": "^2.4.0",
    "@types/multer": "^1.4.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0",
    "mongodb-memory-server": "^10.0.0"
  }
}
