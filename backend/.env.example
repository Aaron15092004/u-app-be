# Server
NODE_ENV=development
PORT=3000

# Database
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/u-app?retryWrites=true&w=majority

# Auth
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
REDEEM_CODE_PEPPER=<chuỗi_hex_vừa_tạo>

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# AI (LogMeal / Gemini)
LOGMEAL_API_KEY=
GEMINI_API_KEY=
# Pin two distinct vision-capable production models from your paid Gemini project.
# Do not use a moving *-latest alias in production.
# Leave blank to use the service's built-in model ladder.
GEMINI_PRIMARY_MODEL=
GEMINI_FALLBACK_MODEL=
# Gemini 2.5/3.x spend output tokens on reasoning before answering — keep this
# generous or requests time out mid-answer. Mobile aborts /scan at 45s.
GEMINI_REQUEST_TIMEOUT_MS=20000

# Email (Resend)
RESEND_API_KEY=

# Deep Linking
APP_DEEP_LINK_BASE=uapp://

# OAuth
GOOGLE_OAUTH_CLIENT_ID_WEB=
GOOGLE_OAUTH_CLIENT_ID_IOS=
GOOGLE_OAUTH_CLIENT_ID_ANDROID=
APPLE_BUNDLE_ID=com.uapp.health

# CORS
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:19006

# Shop URL (Phase 5)
SHOP_URL=https://www.facebook.com/profile.php?id=61589742576832
